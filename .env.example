# Copy this file to .env (or export the variables) to enable API-backed modules.
# All keys are optional; modules without a key are skipped gracefully.

# GitHub personal access token (code/repository search)
GITHUB_TOKEN=

# VirusTotal API key
VIRUSTOTAL_API_KEY=

# Shodan API key
SHODAN_API_KEY=

# SecurityTrails API key
SECURITYTRAILS_API_KEY=

# Censys API credentials
CENSYS_API_ID=
CENSYS_API_SECRET=
